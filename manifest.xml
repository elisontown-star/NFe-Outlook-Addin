<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
  xsi:type="MailApp">

  <Id>430e983e-fb48-455b-812a-2a2831db2652</Id>
  <Version>1.2.0.0</Version>
  <ProviderName>Sua Empresa</ProviderName>
  <DefaultLocale>pt-BR</DefaultLocale>
  <DisplayName DefaultValue="Emissor de NF"/>
  <Description DefaultValue="Atalhos para os portais oficiais de emissao de Nota Fiscal (NF-e, NFC-e e NFS-e)."/>
  <IconUrl DefaultValue="https://elisontown-star.github.io/NFe-Outlook-Addin/icon-64.png?v=4"/>
  <HighResolutionIconUrl DefaultValue="https://elisontown-star.github.io/NFe-Outlook-Addin/icon-128.png?v=4"/>
  <SupportUrl DefaultValue="https://github.com/elisontown-star/NFe-Outlook-Addin"/>

  <AppDomains>
    <AppDomain>https://www.nfse.gov.br</AppDomain>
    <AppDomain>https://www.gov.br</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.1"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://elisontown-star.github.io/NFe-Outlook-Addin/taskpane.html"/>
        <RequestedHeight>250</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
  </Rule>

  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.3">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>
    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <FunctionFile resid="Commands.Url"/>
          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="NfeGroup">
                <Label resid="NfeGroup.Label"/>
                <Control xsi:type="Button" id="NfeTaskpaneButton">
                  <Label resid="NfeTaskpaneButton.Label"/>
                  <Supertip>
                    <Title resid="NfeTaskpaneButton.Label"/>
                    <Description resid="NfeTaskpaneButton.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="Taskpane.Url"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://elisontown-star.github.io/NFe-Outlook-Addin/icon-16.png?v=4"/>
        <bt:Image id="Icon.32x32" DefaultValue="https://elisontown-star.github.io/NFe-Outlook-Addin/icon-32.png?v=4"/>
        <bt:Image id="Icon.80x80" DefaultValue="https://elisontown-star.github.io/NFe-Outlook-Addin/icon-80.png?v=4"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Commands.Url" DefaultValue="https://elisontown-star.github.io/NFe-Outlook-Addin/commands.html"/>
        <bt:Url id="Taskpane.Url" DefaultValue="https://elisontown-star.github.io/NFe-Outlook-Addin/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="NfeGroup.Label" DefaultValue="Notas Fiscais"/>
        <bt:String id="NfeTaskpaneButton.Label" DefaultValue="Emitir NF"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="NfeTaskpaneButton.Tooltip" DefaultValue="Abre o painel com atalhos para os portais oficiais de emissao de NF-e, NFC-e e NFS-e"/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
